{
  "name": "richard-automotive",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "dotenvx run -- next dev",
    "build": "dotenvx run -- next build",
    "start": "next start",
    "bun:dev": "bun --bun next dev",
    "bun:build": "bun --bun next build",
    "deploy:vercel": "dotenvx run -- bun x vercel --prod",
    "test": "dotenvx run -- vitest run --exclude \".agents/**\" --exclude \"e2e/**\" --exclude \"richard-qwik-marketplace/**\"",
    "test:e2e": "npx playwright test",
    "test:e2e:smoke": "npx playwright test e2e/boot-smoke.spec.ts --project=chromium",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 500",
    "predeploy": "bun run build",
    "deploy:firebase:rules": "firebase use richard-automotive && firebase deploy --only firestore:rules",
    "deploy:firebase:indexes": "firebase use richard-automotive && firebase deploy --only firestore:indexes",
    "deploy:firebase:functions": "firebase use richard-automotive && firebase deploy --only functions",
    "deploy:firebase:full": "firebase use richard-automotive && firebase deploy",
    "optimize": "node scripts/optimize-assets.js",
    "sitemap:generate": "tsx scripts/generate-sitemap.ts",
    "commit": "cz",
    "prepare": "husky",
    "format": "npx prettier --write \"src/**/*.{ts,tsx,js,jsx,css,md}\" \"README.md\"",
    "sync:notebook": "npx -y @dotenvx/dotenvx run -- tsx scripts/sync-to-notebook.ts"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/camera": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/device": "^8.0.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/local-notifications": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.1",
    "@dataconnect/admin-generated": "file:src/dataconnect-admin-generated",
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@dotenvx/dotenvx": "^1.52.0",
    "@google/genai": "^1.43.0",
    "@google/generative-ai": "^0.24.1",
    "@ionic/pwa-elements": "^3.4.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-query": "^5.95.2",
    "@types/canvas-confetti": "^1.9.0",
    "@vercel/node": "^5.6.10",
    "ai": "^4.1.20",
    "autoprefixer": "^10.4.27",
    "canvas-confetti": "^1.9.4",
    "capacitor-voice-recorder": "^7.0.6",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^11.11.17",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "js-cookie": "^3.0.5",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.477.0",
    "next": "latest",
    "postcss": "^8.5.9",
    "postcss-nesting": "^14.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-ga4": "^2.1.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "rxjs": "^7.8.2",
    "sharp": "latest",
    "tailwindcss": "^4.2.2",
    "twilio": "^5.12.2",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^10.0.1",
    "@google-cloud/bigquery": "^8.1.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/jspdf": "^2.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^13.7.0",
    "firebase-tools": "^15.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vercel": "^50.25.6",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "fast-xml-parser": "^4.4.1",
    "serialize-javascript": "^6.0.2",
    "tar": "^6.2.1",
    "tmp": "^0.2.4",
    "undici": "^7.24.6"
  }
}
