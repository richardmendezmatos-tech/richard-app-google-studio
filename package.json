    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
