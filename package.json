    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.16.0",
    "memjs": "^1.3.2",
    "next": "^16.2.4",
