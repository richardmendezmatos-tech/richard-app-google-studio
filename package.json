{
  "name": "richard-automotive",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "bin": {
    "sentinel": "./bin/sentinel.js"
  },
  "engines": {
    "node": "^22.0.0 || ^25.0.0"
  },
  "scripts": {
    "dev": "dotenvx run -- next dev",
    "build": "next build --webpack",
    "start": "next start",
    "deploy:vercel": "dotenvx run -- npx vercel --prod",
    "test": "dotenvx run -- vitest run --exclude \".agents/**\" --exclude \"e2e/**\" --exclude \"richard-qwik-marketplace/**\"",
    "test:e2e": "npx playwright test",
    "test:e2e:smoke": "npx playwright test e2e/boot-smoke.spec.ts --project=chromium",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 500",
    "predeploy": "npm run build",
    "optimize": "node scripts/optimize-assets.js",
    "sitemap:generate": "dotenvx run -- tsx scripts/generate-sitemap.ts",
    "commit": "node scripts/sentinel-commit.js",
    "sentinel:commit": "node scripts/sentinel-commit.js",
    "sentinel:deploy": "node scripts/sentinel-deploy.js",
    "prepare": "husky",
    "format": "npx prettier --write \"src/**/*.{ts,tsx,js,jsx,css,md}\" \"README.md\"",
    "sync:notebook": "npx -y @dotenvx/dotenvx run -- tsx scripts/sync-to-notebook.ts",
    "circular": "madge --circular --extensions ts,tsx --exclude 'shared/vendor/kalidokit' --ts-config tsconfig.json src/"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.73",
    "@ai-sdk/react": "^3.0.182",
