#!/usr/bin/env sh
# .husky/pre-commit — Richard Automotive v2026.1
# Runs lint + unit tests before every commit.
# Aborts the commit if either fails.

# Ensure npm/node are in PATH (git uses a restricted environment; npm lives under nvm)
export PATH="$HOME/.nvm/versions/node/v24.14.1/bin:$PATH"

echo "🔍 [PRE-COMMIT] Running linter..."
npm run lint
LINT_EXIT=$?

if [ $LINT_EXIT -ne 0 ]; then
  echo "❌ [PRE-COMMIT] Lint failed. Fix errors before committing."
  exit 1
fi

echo "🧪 [PRE-COMMIT] Running unit tests..."
npm test
TEST_EXIT=$?

if [ $TEST_EXIT -ne 0 ]; then
  echo "❌ [PRE-COMMIT] Tests failed. All tests must pass before committing."
  exit 1
fi

echo "✅ [PRE-COMMIT] Lint and tests passed. Proceeding with commit."
